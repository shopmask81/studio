
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Public read access for general content.
     */
    match /banners/{bannerId} {
      allow get: if true;
      allow list: if request.query.where.get('active', false) == true || isAdmin();
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Cached Data Rules.
     */
    match /cachedData/{docId} {
      allow write: if isAdmin();
      allow read: if isAdmin();
      allow get: if isSignedIn() && (
        docId == 'affiliate_orders_' + request.auth.uid ||
        docId == 'affiliate_stats_' + request.auth.uid
      );
    }

    /**
     * @description Allows reading and writing messages.
     */
    match /messages/{messageId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid || request.resource.data.recipientId == request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Order Management Rules
     */
    match /orders/{orderId} {
      allow create: if isOwner(request.resource.data.userId) || request.resource.data.userId == 'guest';
      allow get: if isAdmin() || isOwner(resource.data.userId);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Product Rules
     */
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Affiliate Rules
     */
    match /affiliates/{affiliateId} {
      // Allow admin and owners to see details
      allow get: if true; 
      
      // CRITICAL FIX: Allow public lookup by code during checkout
      // We restrict this to limit(1) to prevent scraping the whole list.
      allow list: if isAdmin() 
                  || (isSignedIn() && request.query.where.userId == request.auth.uid)
                  || (request.query.limit == 1 && request.query.where.code != null);
      
      allow create: if isAdmin();
      
      // Allow checkout process to increment stats
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalOrders', 'totalEarnings', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    /**
     * @description User Profile Rules
     */
    match /users/{userId} {
      allow create: if isOwner(userId) || isAdmin();
      allow read: if isSignedIn();
      allow list: if isAdmin();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /cart/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'MUhB93iWtkbZ1AWzaE5MYo4Qxvy2' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}
