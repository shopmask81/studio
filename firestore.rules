
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Public read access for general content.
     */
    match /banners/{bannerId} {
      // Anyone can get a single banner document directly.
      allow get: if true;
      // Allow public listing ONLY when querying for active banners.
      // Admins are allowed to list all banners without restriction.
      allow list: if request.query.where.get('active', false) == true || isAdmin();
      // Only admins can create, update, or delete banners.
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Allows reading and writing messages.
     */
    match /messages/{messageId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid || request.resource.data.recipientId == request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Order Management Rules
     */
    match /orders/{orderId} {
      // Allow user to create their own order
      allow create: if isOwner(request.resource.data.userId);
      // Allow user to read their own orders, and admin to read any order
      allow get: if isOwner(resource.data.userId) || isAdmin();
      // Allow admin to list all orders
      allow list: if isAdmin();
      // Allow admin to update orders (e.g., status)
      allow update: if isAdmin();
      // Allow admin to delete orders
      allow delete: if isAdmin();
    }

    /**
     * @description Product Rules
     */
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Only admins can create, update, or delete products
      allow write: if isAdmin();
    }

    /**
     * @description User Profile Rules
     */
    match /users/{userId} {
      // A user can create their own profile document
      allow create: if isOwner(userId);
      // Allow any signed-in user to read any user profile.
      // This is necessary for the isAdmin() check to work in other rules.
      allow read: if isSignedIn();
      // A user can update or delete their own profile
      allow update, delete: if isExistingOwner(userId);
      // No one can list all users for privacy
      allow list: if false;

      /**
       * @description Subcollection rules for user-specific data
       */
      match /cart/{productId} {
        allow read, write: if isOwner(userId);
      }
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      // Check if the user's document in the 'users' collection has the 'admin' role.
      // This requires a broad read rule on the users collection.
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.uid == 'MUhB93iWtkbZ1AWzaE5MYo4Qxvy2'
      );
    }
  }
}
