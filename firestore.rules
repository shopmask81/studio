
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows a user to manage their own affiliate data.
     * @path /affiliates/{affiliateId}
     */
    match /affiliates/{affiliateId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Public read access for general content.
     */
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Allows reading and writing messages.
     */
    match /messages/{messageId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid || request.resource.data.recipientId == request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Order Management Rules
     */
    match /orders/{orderId} {
      // Allow user to create their own order
      allow create: if isOwner(request.resource.data.userId);
      // Allow user to read their own orders, and admin to read any order
      allow get: if isOwner(resource.data.userId) || isAdmin();
      // Allow admin to list all orders
      allow list: if isAdmin();
      // Allow admin to update orders (e.g., status)
      allow update: if isAdmin();
      // Prevent deletion of orders for data integrity
      allow delete: if false;
    }

    /**
     * @description Product Rules
     */
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Only admins can create, update, or delete products
      allow write: if isAdmin();
    }

    /**
     * @description User Profile Rules
     */
    match /users/{userId} {
      // A user can create their own profile document
      allow create: if isOwner(userId);
      // A user can read their own document (important for isAdmin() to work)
      allow read: if isOwner(userId);
      // A user can update or delete their own profile
      allow update, delete: if isExistingOwner(userId);
      // No one can list all users for privacy
      allow list: if false;

      /**
       * @description Subcollection rules for user-specific data
       */
      match /cart/{productId} {
        allow read, write: if isOwner(userId);
      }
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      // Check if the user's document in the 'users' collection has the 'admin' role.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
