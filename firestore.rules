
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Public read access for general content.
     */
    match /banners/{bannerId} {
      allow get: if true;
      allow list: if request.query.where.get('active', false) == true || isAdmin();
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Public read access for cached data.
     */
    match /cachedData/{docId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Allows reading and writing messages.
     */
    match /messages/{messageId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid || request.resource.data.recipientId == request.auth.uid);
      allow update, delete: if false;
    }

    /**
     * @description Order Management Rules
     */
    match /orders/{orderId} {
      allow create: if isOwner(request.resource.data.userId) || request.resource.data.userId == 'guest';
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 50 && request.query.where.affiliateCode != null);
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalOrders', 'totalEarnings']));
      allow delete: if isAdmin();
    }

    /**
     * @description Product Rules
     */
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Affiliate Rules
     */
    match /affiliates/{affiliateId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && request.query.where.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description User Profile Rules
     */
    match /users/{userId} {
      allow create: if isOwner(userId) || isAdmin();
      allow read: if isSignedIn();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /cart/{productId} {
        allow read, write: if isOwner(userId);
      }
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        // Check hardcoded UID FIRST for immediate short-circuiting
        request.auth.uid == 'MUhB93iWtkbZ1AWzaE5MYo4Qxvy2' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
  }
}
